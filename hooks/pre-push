#!/usr/bin/env bash
# hooks/pre-push — runs before `git push` transmits anything.
# Exits 0 to allow the push; non-zero to block it.
#
# Git feeds one line per ref on stdin:
#   <local ref> <local sha1> <remote ref> <remote sha1>
#
# The remote sha1 is 40 zeros when the remote ref does not yet exist.

set -euo pipefail

# --- Colors (optional, stripped if stdout is not a TTY) ---
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'   # no color
else
    RED='' GREEN='' YELLOW='' NC=''
fi

# ─── Hook helpers ──────────────────────────────────────────────
pass()  { printf "${GREEN}[PASS]${NC} %s\n" "$*"; }
fail()  { printf "${RED}[FAIL]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$*"; }

# ─── Your checks go here ───────────────────────────────────────
# Each function should return 0 (ok) or non-zero (fail).
# Add or remove functions below.

run_checks() {
    # Example: block pushes to main/master unless you're on a named branch
    # check_protected_branch

    # Example: run the test suite
    # check_tests

    # Example: lint
    # check_lint

    # Add your own checks here…

    return 0
}

# ─── Example check implementations ─────────────────────────────

check_protected_branch() {
    local remote_ref="$1"
    # Block force-pushes to main / master
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            warn "pushing to protected branch '$remote_ref'"
            # return 1   # uncomment to actually block
            ;;
    esac
}

check_tests() {
    # Replace with your actual test runner
    if command -v cargo >/dev/null 2>&1; then
        cargo test --quiet || { fail "tests failed"; return 1; }
    elif command -v go >/dev/null 2>&1; then
        go test ./... || { fail "tests failed"; return 1; }
    else
        warn "no test runner detected — skipping tests"
    fi
    pass "tests"
}

check_lint() {
    if command -v cargo >/dev/null 2>&1 && [ -f Cargo.toml ]; then
        cargo clippy -- -D warnings || { fail "clippy"; return 1; }
    fi
    pass "lint"
}

# ─── Main ──────────────────────────────────────────────────────

FAILED=0

while read -r local_ref local_sha remote_ref remote_sha; do
    printf "\n→ pushing %s  (%s → %s)\n" "$local_ref" "${local_sha:0:7}" "$remote_ref"

    if ! run_checks "$local_ref" "$local_sha" "$remote_ref" "$remote_sha"; then
        FAILED=1
    fi
done

if [ "$FAILED" -ne 0 ]; then
    printf "\n${RED}Pre-push checks failed — push blocked.${NC}\n"
    exit 1
fi

printf "\n${GREEN}All pre-push checks passed.${NC}\n"
exit 0

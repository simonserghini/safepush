#!/usr/bin/env bash
# ┌─────────────────────────────────────────────────────────────┐
# │  safepush — pre-push hook                                  │
# │                                                             │
# │  Runs right before `git push` sends your code to the       │
# │  remote.  This is your last chance to ask: "wait, should   │
# │  I really be doing this?"                                  │
# │                                                             │
# │  We don't do heavy scanning here — that already happened    │
# │  during pre-commit.  These are the push-specific checks.    │
# │                                                             │
# │  Git gives us info about what's being pushed on stdin:      │
# │    <local ref> <local sha> <remote ref> <remote sha>        │
# └─────────────────────────────────────────────────────────────┘
set -euo pipefail

# ── Real human or CI bot? ────────────────────────────────────
INTERACTIVE=false
[ -t 0 ] && INTERACTIVE=true

# ── Terminal colors ──────────────────────────────────────────
if [ -t 1 ]; then
    RED='\033[0;31m'      GREEN='\033[0;32m'    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'     MAGENTA='\033[0;35m'  BOLD='\033[1m'
    DIM='\033[2m'         NC='\033[0m'          REV='\033[7m'
else
    RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' BOLD='' DIM='' NC='' REV=''
fi

# ── State ────────────────────────────────────────────────────
BLOCK_PUSH=false
FOUND_ANYTHING=false

# ── Helpers ──────────────────────────────────────────────────
section()   { printf "\n${BOLD}${CYAN}━━━ %s ━━━${NC}\n" "$*"; }
pass()      { printf "  ${GREEN}✓${NC} %s\n" "$*"; }
fail()      { printf "  ${RED}✗${NC} %s\n" "$*"; }
warn()      { printf "  ${YELLOW}⚠${NC}  %s\n" "$*"; }
info()      { printf "  ${DIM}→${NC} %s\n" "$*"; }

ask() {
    local prompt="$1"
    local default="${2:-N}"
    if $INTERACTIVE; then
        local hint
        [ "$default" = "Y" ] && hint="Y/n" || hint="y/N"
        printf "  ${YELLOW}?${NC} ${prompt} ${DIM}[${hint}]${NC} "
        read -r answer
        answer="${answer:-$default}"
        case "${answer,,}" in y|yes) return 0 ;; *) return 1 ;; esac
    else
        echo "  ${DIM}→${NC} ${prompt}  ${DIM}(non-interactive — proceeding)${NC}"
        return 0
    fi
}

# ── The big entrance — you can't miss this ────────────────────
entry_show() {
    clear 2>/dev/null || true
    printf "${REV}${BOLD}  ╔══════════════════════════════════════════════════╗  ${NC}\n"
    printf "${REV}${BOLD}  ║${NC}  ${BOLD}WOW WOW WOW!  hold up a second…${NC}              ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ║${NC}  ${DIM}You're about to push code to the world.${NC}       ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ║${NC}  ${BOLD}Let's do one last sanity check.${NC}            ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ╚══════════════════════════════════════════════════╝  ${NC}\n"
    sleep 1 2>/dev/null || true
    echo ""
}

# ═══════════════════════════════════════════════════════════════
#  THE CHECKS
#  These are push-specific — things that only matter when your
#  code is about to leave your machine.
# ═══════════════════════════════════════════════════════════════

# ── Force push — the nuclear option ───────────────────────────
# Git tells us the remote SHA.  If your local branch is NOT a
# descendant of the remote, that means you're rewriting history.
# This can delete other people's work.  We ask very firmly.
#
# If the remote SHA is all zeros, this is a first push — no
# history to rewrite, so we let it through.
check_force_push() {
    local local_ref="$1" local_sha="$2" remote_ref="$3" remote_sha="$4"

    # First push to this branch?  Nothing to force.
    [[ "$remote_sha" =~ ^0{40}$ ]] && { pass "First push to this ref — nothing to force"; return 0; }

    # Is local a descendant of remote?  That's a normal fast-forward push.
    if git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
        pass "Fast-forward push — all good"
        return 0
    fi

    # Uh oh.  Your branch and the remote have diverged.
    fail "Force push detected!  (${remote_ref#refs/heads/} will lose commits)"
    warn "Local ${local_sha:0:7} is NOT a descendant of remote ${remote_sha:0:7}"
    FOUND_ANYTHING=true

    if ask "This will REWRITE history on the remote. Are you ABSOLUTELY sure?"; then
        warn "Force push confirmed.  Hope you know what you're doing."
    else
        BLOCK_PUSH=true
    fi
}

# ── Protected branch — "are you pushing straight to main?" ────
# Pushing directly to main/master skips code review.
# We warn you, because you probably meant to open a PR instead.
# First push to a protected branch is fine — you're creating it.
check_protected_branch() {
    local remote_ref="$1"
    local remote_sha="$2"

    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            FOUND_ANYTHING=true
            if [[ ! "$remote_sha" =~ ^0{40}$ ]]; then
                warn "Pushing directly to ${remote_ref#refs/heads/} — did you mean to open a PR?"
                ask "Push directly to ${remote_ref#refs/heads/} anyway?" || BLOCK_PUSH=true
            else
                pass "First push to ${remote_ref#refs/heads/} — go ahead"
            fi
            ;;
        *)
            pass "Pushing to ${remote_ref#refs/heads/}"
            ;;
    esac
}

# ── Unstaged changes — "you forgot to git add these" ──────────
# If you've modified tracked files but haven't staged them,
# they WON'T be included in the push.  Maybe that's intentional,
# maybe it's a mistake.  We point it out so you can decide.
check_unstaged_changes() {
    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        [ "$hits" -eq 1 ] && warn "Tracked files modified but NOT staged:"
        printf "    ${YELLOW}→${NC} %s\n" "$line"
    done < <(git status --porcelain=v1 2>/dev/null | grep '^.[MDU]' || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        info "Found $hits file(s) with unstaged changes — they WON'T be pushed."
        ask "Push anyway (unstaged changes stay local)?" || BLOCK_PUSH=true
    else
        pass "Worktree clean"
    fi
}

# ── Commit messages — "is that really the best you've got?" ───
# We check every commit that's about to be pushed (not just the
# latest one).  Messages under 8 characters are flagged.
# "fix", "wip", "oops" — come on, you can do better than that.
check_commit_messages() {
    local range
    range=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")

    local hits=0
    # Walk from HEAD back to origin/HEAD — every pending commit
    while IFS= read -r msg; do
        [ -z "$msg" ] && continue
        local len=${#msg}
        if [ "$len" -lt 8 ]; then
            hits=$((hits + 1))
            [ "$hits" -eq 1 ] && warn "Short commit messages (under 8 chars):"
            printf "    ${YELLOW}→${NC} %s  ${DIM}(%d chars)${NC}\n" "$msg" "$len"
        fi
    done < <(git log --oneline --format='%s' origin/HEAD..HEAD 2>/dev/null || git log --oneline --format='%s' -5 2>/dev/null || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        ask "Some commit messages are pretty short. Push anyway?" || BLOCK_PUSH=true
    else
        pass "Commit messages look fine"
    fi
}

# ── Untracked files — "did you forget to add these?" ──────────
# Files that exist in your working directory but aren't tracked
# by git.  Maybe they're build artifacts, maybe they're important
# new files you forgot to `git add`.  We show the top 20.
check_untracked() {
    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        [ "$hits" -eq 1 ] && info "Untracked files that look important:"
        printf "    ${DIM}→${NC} %s\n" "$line"
    done < <(git ls-files --others --exclude-standard | grep -ivE '(\.lock|\.tmp|\.swp|node_modules/|target/|__pycache__/)' | head -20 || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        info "Found $hits untracked file(s) — maybe add them before pushing?"
        ask "Push anyway?" || BLOCK_PUSH=true
    else
        pass "Nothing important untracked"
    fi
}

# ═══════════════════════════════════════════════════════════════
#  MAIN — read what git tells us, run the checks, give a verdict
# ═══════════════════════════════════════════════════════════════

entry_show

FAILED=0

# Git sends us one line per ref being pushed.  Usually just one.
while read -r local_ref local_sha remote_ref remote_sha; do
    printf "  ${BOLD}Pushing${NC}  %s ${CYAN}→${NC} %s\n" \
        "$local_ref" \
        "${remote_ref#refs/heads/}"
    echo ""

    check_force_push        "$local_ref" "$local_sha" "$remote_ref" "$remote_sha"
    check_protected_branch  "$remote_ref" "$remote_sha"
    check_unstaged_changes
    check_commit_messages
    check_untracked

    if $BLOCK_PUSH; then
        FAILED=1
    fi
done

# ── The final word ────────────────────────────────────────────
echo ""
if [ "$FAILED" -ne 0 ]; then
    printf "${BOLD}${REV}  PUSH BLOCKED  ${NC}\n\n"
    printf "  ${RED}Fix the issues above and try again.${NC}\n\n"
    exit 1
fi

if $FOUND_ANYTHING; then
    printf "${BOLD}${GREEN}  PUSH ALLOWED  ${NC}\n\n"
    printf "  ${GREEN}Checks found things, but you gave the green light.${NC}\n"
    printf "  ${DIM}Godspeed.${NC}\n\n"
else
    printf "${BOLD}${GREEN}  ALL CLEAR — PUSHING  ${NC}\n\n"
    printf "  ${DIM}Carry on.${NC}\n\n"
fi

exit 0

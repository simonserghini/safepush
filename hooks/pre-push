#!/usr/bin/env bash
# hooks/pre-push — your last line of defence before code leaves your machine.
# Runs before every `git push`.  Exits 0 to allow; non-zero to block.
#
# Git feeds one line per ref on stdin:
#   <local ref> <local sha1> <remote ref> <remote sha1>

set -euo pipefail

# ─── TTY detection ─────────────────────────────────────────────
INTERACTIVE=false
[ -t 0 ] && INTERACTIVE=true   # stdin is a terminal → we can ask questions

# ─── Colors ────────────────────────────────────────────────────
if [ -t 1 ]; then
    RED='\033[0;31m'      GREEN='\033[0;32m'    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'     MAGENTA='\033[0;35m'  BOLD='\033[1m'
    DIM='\033[2m'         NC='\033[0m'          REV='\033[7m'
else
    RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' BOLD='' DIM='' NC='' REV=''
fi

# ─── State ─────────────────────────────────────────────────────
FOUND_ANYTHING=false      # did any scan find something worth reporting?
BLOCK_PUSH=false           # set to true when something is a hard blocker
SCAN_COUNT=0

# ─── Helpers ───────────────────────────────────────────────────
banner()    { printf "\n${BOLD}${MAGENTA}%s${NC}\n" "$*"; }
section()   { printf "\n${BOLD}${CYAN}━━━ %s ━━━${NC}\n" "$*"; }
pass()      { printf "  ${GREEN}✓${NC} %s\n" "$*"; }
fail()      { printf "  ${RED}✗${NC} %s\n" "$*"; }
warn()      { printf "  ${YELLOW}⚠${NC}  %s\n" "$*"; }
info()      { printf "  ${DIM}→${NC} %s\n" "$*"; }

# Ask the user a yes/no question.  Returns 0 for yes, 1 for no.
# Falls back to "yes" when non-interactive (CI: don't block the pipeline).
ask() {
    local prompt="$1"
    local default="${2:-N}"
    if $INTERACTIVE; then
        local hint
        [ "$default" = "Y" ] && hint="Y/n" || hint="y/N"
        printf "  ${YELLOW}?${NC} ${prompt} ${DIM}[${hint}]${NC} "
        read -r answer
        answer="${answer:-$default}"
        case "${answer,,}" in y|yes) return 0 ;; *) return 1 ;; esac
    else
        echo "  ${DIM}→${NC} ${prompt}  ${DIM}(non-interactive — proceeding)${NC}"
        return 0
    fi
}

# ─── THE ENTRY ─────────────────────────────────────────────────
entry_show() {
    clear 2>/dev/null || true
    printf "${REV}${BOLD}  ╔══════════════════════════════════════════════════╗  ${NC}\n"
    printf "${REV}${BOLD}  ║${NC}  ${BOLD}WOW WOW WOW!  hold up a second…${NC}              ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ║${NC}  ${DIM}You're about to push code to the world.${NC}       ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ║${NC}  ${BOLD}Let's scan it first.  Better safe than sorry.${NC} ${REV}${BOLD}║${NC}  \n"
    printf "${REV}${BOLD}  ╚══════════════════════════════════════════════════╝  ${NC}\n"
    sleep 1.5 2>/dev/null || true
    echo ""
}

# ─── SCANS ─────────────────────────────────────────────────────
#
# Each scan_* function returns 0 if clean, or sets FOUND_ANYTHING=true
# and optionally BLOCK_PUSH=true when it finds something.  The function
# itself always returns 0 (the scan itself never aborts — the user
# decides via prompts).

scan_secrets() {
    section "Scanning for secrets  (API keys, tokens, passwords…)"

    local patterns=(
        # Generic API-key / token shaped
        '[a-zA-Z0-9_]*[_-]?(api[_-]?key|apikey|API_KEY)\s*[=:]\s*['\''"][a-zA-Z0-9_\-]{12,}['\''"]'
        '[a-zA-Z0-9_]*[_-]?(secret|SECRET)\s*[=:]\s*['\''"][a-zA-Z0-9_\-]{8,}['\''"]'
        '[a-zA-Z0-9_]*[_-]?(token|TOKEN|access_token)\s*[=:]\s*['\''"][a-zA-Z0-9_\-.]{12,}['\''"]'
        '[a-zA-Z0-9_]*[_-]?(password|PASSWORD|passwd)\s*[=:]\s*['\''"][^'\''"]{4,}['\''"]'
        # Common service patterns
        'sk-[a-zA-Z0-9]{20,}'                           # OpenAI
        'ghp_[a-zA-Z0-9]{36}'                            # GitHub PAT
        'github_pat_[a-zA-Z0-9_]{22,}'                   # GitHub fine-grained
        'AKIA[0-9A-Z]{16}'                               # AWS access key
        'xox[baprs]-[0-9a-zA-Z-]{10,}'                   # Slack tokens
    )

    local hits=0
    local pattern
    for pattern in "${patterns[@]}"; do
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            hits=$((hits + 1))
            if [ "$hits" -eq 1 ]; then
                warn "Possible secrets found:"
            fi
            printf "    ${RED}→${NC} %s\n" "$line"
        done < <(git diff --cached --unified=0 2>/dev/null | grep -iE "$pattern" || true)
    done

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        if ask "Secrets detected! Push anyway?"; then
            warn "Pushing WITH secrets — hope you know what you're doing."
        else
            BLOCK_PUSH=true
        fi
    else
        pass "No secrets detected"
    fi
}

scan_large_files() {
    section "Scanning for large files  (≥ 1 MB)"

    local threshold=1048576  # 1 MB
    local hits=0

    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            warn "Large files in this push:"
        fi
        # line format from git diff-tree: :mode mode old_sha new_sha status\tpath
        local sha path
        sha=$(echo "$line" | awk '{print $4}')
        path=$(echo "$line" | cut -f2)
        local size
        size=$(git cat-file -s "$sha" 2>/dev/null || echo 0)
        if [ "$size" -gt "$threshold" ]; then
            printf "    ${YELLOW}→${NC} %s  ${DIM}(%s)${NC}\n" "$path" "$(numfmt --to=iec "$size" 2>/dev/null || echo "${size} bytes")"
        fi
    done < <(git diff --cached --diff-filter=A --raw 2>/dev/null || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        ask "Large files detected. Push anyway?" || BLOCK_PUSH=true
    else
        pass "No large files"
    fi
}

scan_merge_conflicts() {
    section "Scanning for merge-conflict markers"

    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            fail "Leftover merge-conflict markers:"
        fi
        printf "    ${RED}→${NC} %s\n" "$line"
    done < <(git diff --cached -U0 2>/dev/null | grep -nE '^(\+<<<<<<<|\+=======|\+>>>>>>>)' || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        BLOCK_PUSH=true
        fail "Merge conflicts must be resolved before pushing."
    else
        pass "No merge conflicts"
    fi
}

scan_todos() {
    section "Scanning for TODO / FIXME / HACK markers"

    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            info "You left these behind:"
        fi
        printf "    ${DIM}→${NC} %s\n" "$line"
    done < <(git diff --cached -U0 2>/dev/null | grep -nE '^\+\s*(TODO|FIXME|HACK|XXX|TEMP|WORKAROUND)' || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        ask "Found $hits TODO/FIXME markers. Push anyway?" || BLOCK_PUSH=true
    else
        pass "No forgotten markers"
    fi
}

scan_debug_prints() {
    section "Scanning for debug prints  (console.log, println!, dbg!, print())"

    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            warn "Debug output in staged changes:"
        fi
        printf "    ${YELLOW}→${NC} %s\n" "$line"
    done < <(git diff --cached -U0 2>/dev/null | grep -nE '^\+\s*(console\.(log|debug|warn)|println!|dbg!|print\(|printf\(|echo|var_dump|dump\()' || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        ask "Debug prints detected. Push anyway?" || BLOCK_PUSH=true
    else
        pass "No debug prints"
    fi
}

scan_trailing_whitespace() {
    section "Scanning for trailing whitespace"

    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            warn "Trailing whitespace:"
        fi
        printf "    ${DIM}→${NC} %s\n" "$line"
    done < <(git diff --cached -U0 2>/dev/null | grep -nE '^\+\s+$' || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        if ask "Trailing whitespace found. Strip it now?"; then
            # Only strip lines that are newly added (+)
            local files
            files=$(git diff --cached --name-only 2>/dev/null)
            for f in $files; do
                [ ! -f "$f" ] && continue
                sed -i 's/[[:space:]]*$//' "$f" 2>/dev/null || true
            done
            git add $files 2>/dev/null || true
            pass "Trailing whitespace stripped"
        fi
    else
        pass "No trailing whitespace"
    fi
}

scan_untracked_important() {
    section "Scanning for untracked files you might want to commit"

    local hits=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        hits=$((hits + 1))
        if [ "$hits" -eq 1 ]; then
            info "Untracked files that look important:"
        fi
        printf "    ${DIM}→${NC} %s\n" "$line"
    done < <(git ls-files --others --exclude-standard | grep -ivE '(\.lock|\.tmp|\.swp|node_modules/|target/|__pycache__/)' | head -20 || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        info "Found $hits untracked file(s) — maybe add them before pushing?"
        ask "Push anyway?" || BLOCK_PUSH=true
    else
        pass "Nothing important untracked"
    fi
}

scan_commit_message() {
    section "Checking commit message quality"

    local range
    # Find what's about to be pushed
    range=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")

    local hits=0
    while IFS= read -r msg; do
        [ -z "$msg" ] && continue
        local len=${#msg}

        if [ "$len" -lt 8 ]; then
            hits=$((hits + 1))
            [ "$hits" -eq 1 ] && warn "Short commit messages (under 8 chars):"
            printf "    ${YELLOW}→${NC} %s  ${DIM}(%d chars)${NC}\n" "$msg" "$len"
        fi
    done < <(git log --oneline --format='%s' origin/HEAD..HEAD 2>/dev/null || git log --oneline --format='%s' -5 2>/dev/null || true)

    if [ "$hits" -gt 0 ]; then
        FOUND_ANYTHING=true
        ask "Some commit messages are pretty short. Push anyway?" || BLOCK_PUSH=true
    else
        pass "Commit messages look fine"
    fi
}

# ─── Main sausage ──────────────────────────────────────────────

entry_show

FAILED=0
SCANNED=0

while read -r local_ref local_sha remote_ref remote_sha; do
    printf "  ${BOLD}Pushing${NC}  %s ${CYAN}→${NC} %s\n" \
        "$local_ref" \
        "${remote_ref#refs/heads/}"
    echo ""

    # ── Run every scan ──────────────────────────────────────
    scan_secrets
    scan_large_files
    scan_merge_conflicts
    scan_todos
    scan_debug_prints
    scan_trailing_whitespace
    scan_untracked_important
    scan_commit_message
    SCANNED=$((SCANNED + 1))

    if $BLOCK_PUSH; then
        FAILED=1
    fi
done

# ─── VERDICT ───────────────────────────────────────────────────

echo ""
if [ "$FAILED" -ne 0 ]; then
    printf "${BOLD}${REV}  PUSH BLOCKED  ${NC}\n"
    echo ""
    printf "  ${RED}Some checks didn't pass and you chose not to proceed.${NC}\n"
    printf "  ${DIM}Fix the issues above and try again.${NC}\n"
    echo ""
    exit 1
fi

if $FOUND_ANYTHING; then
    printf "${BOLD}${GREEN}  PUSH ALLOWED  ${NC}\n"
    echo ""
    printf "  ${GREEN}Scans found things, but you gave the green light.${NC}\n"
    printf "  ${DIM}You're the boss.  Godspeed.${NC}\n"
else
    printf "${BOLD}${GREEN}  ALL CLEAR — PUSHING  ${NC}\n"
    echo ""
    printf "  ${GREEN}Everything looks clean.${NC}\n"
    printf "  ${DIM}Carry on.${NC}\n"
fi

echo ""
exit 0
